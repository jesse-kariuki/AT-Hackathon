# BodaShield environment variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# Africa's Talking credentials
# Get these from: https://account.africastalking.com
AT_USERNAME=sandbox
AT_API_KEY=your_api_key_here

# Phone numbers
# OWNER_PHONE = the number that receives alerts (must be verified in AT sandbox)
OWNER_PHONE=+254711000000
# AT_PHONE = your Africa's Talking sender number
AT_PHONE=+254711000001

# Matatu fare per passenger in KES
FARE=50
